{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client", "vitest/globals", "@testing-library/jest-dom", "node"],
    "allowArbitraryExtensions": true,
    "skipLibCheck": true,

    /* `@posthog/react` ships no exports map, so src/lib/posthog-react.ts has to
       import the slim build by its full file path for plain Node ESM (the
       prerender step) to resolve it. TypeScript can't find the types from that
       path on its own — point it at the declarations that ship alongside. */
    "paths": {
      "@posthog/react/dist/esm/slim/index.js": ["./node_modules/@posthog/react/dist/types/slim/index.d.ts"]
    },

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
